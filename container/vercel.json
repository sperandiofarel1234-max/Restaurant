{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/remoteEntry.js",
      "destination": "/remoteEntry.js"
    },
    {
      "source": "/((?!.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|map)).*)",
      "destination": "/index.html"
    }
  ]
}